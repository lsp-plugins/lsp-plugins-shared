<?xml version="1.0"?>

<window ui:inject="LauncherWindow">
	<!-- header -->
	<vbox spacing="4" ui:id="launcher_window">
		<grid rows="2" cols="4" height="44" expand="false" bg.color="bg_schema">
			<cell rows="2" width.min="106">
				<hbox>
					<multilabel padding.left="6" padding.bottom="3" font.scaling="1">
						<label font.name="lsp-logo" font.size="34" font.antialias="true" text="A" color="lsp_logo"/>
						<label font.name="lsp-logo" font.size="34" font.antialias="true" text="B" color="lsp_logo_cover"/>
					</multilabel>
					<void expand="true"/>
				</hbox>
			</cell>
			<cell rows="2" width.min="10"><void expand="true"/></cell>
			<void expand="true"/>
			<cell>
				<hbox>
					<void hexpand="true"/>
					<!-- plugin name -->
					<label color="plug_name" font.bold="true" font.size="14" halign="1" padding.top="2" padding.bottom="-1" padding.right="6" text="labels.rack.plugin_launcher" text.meta="true" text.adjust="toupper"/>
				</hbox>
			</cell>
			<void expand="true"/>

			<!-- Preset and Menu box -->
			<hbox bg.color="bg">
				<void expand="true" bg.color="bg_schema"/>
				<!-- About -->
				<bevel hexpand="false" color="bg_schema" bg.color="bg" width.min="24" height.min="20"/>
				<hbox ui:id="trg_about" solid="true" padding.right="6" pointer="hand">
					<label hover="true" color="menu_icon" font.size="10" hover.color="menu_icon_hover" font.name="lsp-icons" padding.top="1" font.antialias="true" text="4"/>
					<label hover="true" color="menu_text" hover.color="menu_text_hover" padding.left="5" font.size="14" padding.top="3" text="labels.header.about"/>
				</hbox>
			</hbox>
		</grid>
		<hsep ui:inject="LauncherWindow::HSep::Header"/>

		<!-- plugin-content -->
		<vbox ui:inject="LauncherWindow::Content" ui:id="launcher_content">
			<hbox fill="true" bg.color="bg_schema" pad.h="6" pad.v="4" width.min="848">
				<hbox>
					<label text="labels.search" pad.r="6"/>
					<edit ui:id="search_input" width.min="400"/>
				</hbox>
				<void hexpand="true"/>
				<hbox ui:id="trg_language_select_area">
					<label text="lang.language" pad.r="6"/>
					<combo ui:id="trg_language_select" width.min="96"/>
				</hbox>
				<hbox ui:id="trg_visual_schema_select_area" pad.l="12">
					<label text="actions.visual_schema.select" pad.r="6"/>
					<combo ui:id="trg_visual_schema_select" width.min="96"/>
				</hbox>
			</hbox>
			<hsep bg.color="bg" pad.v="2" vreduce="true"/>
			<tabs ui:id="tab_control" expand="true">
				<tab text="With big love to c++">
					<vbox expand="true">
						<label ui:inject="LauncherWindow::Heading" text="With big love to c++" bg.color="bg_schema" pad.v="15"/>
						<void bg.color="bg_name" pad.v="1" vreduce="true"/>
						<sarea expand="true" vscroll="optional" hscale="1">
							<!-- Categoty example -->
							<vbox>
								<label bg.color="bg_name" ui:inject="LauncherWindow::Category::Heading" text="Category A"/>
								<hsep bg.color="bg" pad.v="2" vreduce="true"/>

								<grid rows="4" cols="2" spacing="12" bg.color="bg_schema" pad.v="12" pad.h="6">
									<cell rows="3">
										<vbox>
											<label text="Image" width="128" height="128" bg.color="gray" expand="false" fill="false"/>
											<void vexpand="true"/>
										</vbox>
									</cell>
									<label ui:inject="LauncherWindow::Bundle::Heading" text="Plugin name 1"/>
									<hbox spacing="6">
										<button id="test" ui:inject="LauncherWindow::Bundle::Favourites" text="icons.markers.star_filled_nb"/>
										<button id="test" ui:inject="LauncherWindow::Bundle::Help" text="icons.main.help_nb"/>
										<void hexpand="true"/>
									</hbox>
									<label ui:inject="LauncherWindow::Bundle::Description" text="bundles.slap_delay.description"/>
									<cell cols="2">
										<hbox spacing="6" ui:inject="LauncherWindow::Bundle::Buttons">
											<button id="test_2" text="number 1"/>
											<button id="test_2" text="num"/>
											<button id="test_2" text="number 3"/>
											<button id="test_2" text="number 4"/>
											<button id="test_2" text="nuber 5"/>
											<button id="test_2" text="number 6"/>
											<button id="test_2" text="numbernumber 7"/>
											<button id="test_2" text="number 8"/>
											<button id="test_2" text="num 9"/>
											<button id="test_2" text="number 10"/>
											<button id="test_2" text="number 11"/>
											<button id="test_2" text="er 12"/>
											<void hexpand="true"/>
										</hbox>
									</cell>
								</grid>

								<hsep bg.color="bg" pad.v="2" vreduce="true"/>

								<grid rows="4" cols="2" spacing="12" bg.color="bg_schema" pad.v="12" pad.h="6">
									<cell rows="3">
										<vbox>
											<label text="Image" width="128" height="128" bg.color="gray" expand="false" fill="false"/>
											<void vexpand="true"/>
										</vbox>
									</cell>
									<label ui:inject="LauncherWindow::Bundle::Heading" text="Plugin name 1"/>
									<hbox spacing="6">
										<button id="test" ui:inject="LauncherWindow::Bundle::Favourites" text="icons.markers.star_filled_nb"/>
										<button id="test" ui:inject="LauncherWindow::Bundle::Help" text="icons.main.help_nb"/>
										<void hexpand="true"/>
									</hbox>
									<label ui:inject="LauncherWindow::Bundle::Description" text="bundles.filter.description"/>
									<cell cols="2">
										<hbox spacing="6" ui:inject="LauncherWindow::Bundle::Buttons">
											<button id="test_2" text="number 1"/>
											<button id="test_2" text="num"/>
											<button id="test_2" text="number 11"/>
											<button id="test_2" text="er 12"/>
											<void hexpand="true"/>
										</hbox>
									</cell>
								</grid>

								<hsep bg.color="bg" pad.v="2" vreduce="true"/>

								<grid rows="4" cols="2" spacing="12" bg.color="bg_schema" pad.v="12" pad.h="6">
									<cell rows="3">
										<vbox>
											<label text="Image" width="128" height="128" bg.color="gray" expand="false" fill="false"/>
											<void vexpand="true"/>
										</vbox>
									</cell>
									<label ui:inject="LauncherWindow::Bundle::Heading" text="Plugin name 1"/>
									<hbox spacing="6">
										<button id="test" ui:inject="LauncherWindow::Bundle::Favourites" text="icons.markers.star_filled_nb"/>
										<button id="test" ui:inject="LauncherWindow::Bundle::Help" text="icons.main.help_nb"/>
										<void hexpand="true"/>
									</hbox>
									<label ui:inject="LauncherWindow::Bundle::Description" text="bundles.phaser.description"/>
									<cell cols="2">
										<hbox spacing="6" ui:inject="LauncherWindow::Bundle::Buttons">
											<button id="test_2" text="num 9"/>
											<button id="test_2" text="number 10"/>
											<button id="test_2" text="number 11"/>
											<button id="test_2" text="er 12"/>
											<void hexpand="true"/>
										</hbox>
									</cell>
								</grid>

								<hsep bg.color="bg" pad.v="20" vreduce="true"/>

								<label bg.color="bg_name" ui:inject="LauncherWindow::Category::Heading" text="Category B"/>
								<hsep bg.color="bg" pad.v="2" vreduce="true"/>

								<grid rows="4" cols="2" spacing="12" bg.color="bg_schema" pad.v="12" pad.h="6">
									<cell rows="3">
										<vbox>
											<label text="Image" width="128" height="128" bg.color="gray" expand="false" fill="false"/>
											<void vexpand="true"/>
										</vbox>
									</cell>
									<label ui:inject="LauncherWindow::Bundle::Heading" text="Plugin name 1"/>
									<hbox spacing="6">
										<button id="test" ui:inject="LauncherWindow::Bundle::Favourites" text="icons.markers.star_filled_nb"/>
										<button id="test" ui:inject="LauncherWindow::Bundle::Help" text="icons.main.help_nb"/>
										<void hexpand="true"/>
									</hbox>
									<label ui:inject="LauncherWindow::Bundle::Description" text="bundles.slap_delay.description"/>
									<cell cols="2">
										<hbox spacing="6" ui:inject="LauncherWindow::Bundle::Buttons">
											<button id="test_2" text="number 1"/>
											<button id="test_2" text="num"/>
											<button id="test_2" text="number 3"/>
											<button id="test_2" text="number 4"/>
											<button id="test_2" text="nuber 5"/>
											<button id="test_2" text="number 6"/>
											<button id="test_2" text="numbernumber 7"/>
											<button id="test_2" text="number 8"/>
											<button id="test_2" text="num 9"/>
											<button id="test_2" text="number 10"/>
											<button id="test_2" text="number 11"/>
											<button id="test_2" text="er 12"/>
											<void hexpand="true"/>
										</hbox>
									</cell>
								</grid>

								<hsep bg.color="bg" pad.v="2" vreduce="true"/>

								<grid rows="4" cols="2" spacing="12" bg.color="bg_schema" pad.v="12" pad.h="6">
									<cell rows="3">
										<vbox>
											<label text="Image" width="128" height="128" bg.color="gray" expand="false" fill="false"/>
											<void vexpand="true"/>
										</vbox>
									</cell>
									<label ui:inject="LauncherWindow::Bundle::Heading" text="Plugin name 1"/>
									<hbox spacing="6">
										<button id="test" ui:inject="LauncherWindow::Bundle::Favourites" text="icons.markers.star_filled_nb"/>
										<button id="test" ui:inject="LauncherWindow::Bundle::Help" text="icons.main.help_nb"/>
										<void hexpand="true"/>
									</hbox>
									<label ui:inject="LauncherWindow::Bundle::Description" text="bundles.filter.description"/>
									<cell cols="2">
										<hbox spacing="6" ui:inject="LauncherWindow::Bundle::Buttons">
											<button id="test_2" text="number 1"/>
											<button id="test_2" text="num"/>
											<button id="test_2" text="number 11"/>
											<button id="test_2" text="er 12"/>
											<void hexpand="true"/>
										</hbox>
									</cell>
								</grid>

								<hsep bg.color="bg" pad.v="2" vreduce="true"/>

								<grid rows="4" cols="2" spacing="12" bg.color="bg_schema" pad.v="12" pad.h="6">
									<cell rows="3">
										<vbox>
											<label text="Image" width="128" height="128" bg.color="gray" expand="false" fill="false"/>
											<void vexpand="true"/>
										</vbox>
									</cell>
									<label ui:inject="LauncherWindow::Bundle::Heading" text="Plugin name 1"/>
									<hbox spacing="6">
										<button id="test" ui:inject="LauncherWindow::Bundle::Favourites" text="icons.markers.star_filled_nb"/>
										<button id="test" ui:inject="LauncherWindow::Bundle::Help" text="icons.main.help_nb"/>
										<void hexpand="true"/>
									</hbox>
									<label ui:inject="LauncherWindow::Bundle::Description" text="bundles.phaser.description"/>
									<cell cols="2">
										<hbox spacing="6" ui:inject="LauncherWindow::Bundle::Buttons">
											<button id="test_2" text="num 9"/>
											<button id="test_2" text="number 10"/>
											<button id="test_2" text="number 11"/>
											<button id="test_2" text="er 12"/>
											<void hexpand="true"/>
										</hbox>
									</cell>
								</grid>
							</vbox>
						</sarea>
						<void expand="true"/>
						<!-- End Categoty example -->
					</vbox>
				</tab>
				<tab text="labels.all_plugins">
					<vbox expand="true">
						<label ui:inject="LauncherWindow::Heading" text="labels.all_plugins" bg.color="bg_schema" pad.v="15"/>
						<void bg.color="bg_name" pad.v="1" vreduce="true"/>
						<sarea expand="true" vscroll="optional" hscale="1">
							<vbox ui:id="all_plugins_list" expand="true" pad.v="4" pad.h="6"/>
						</sarea>
					</vbox>
				</tab>
				<tab text="labels.favourites">
					<vbox expand="true">
						<label ui:inject="LauncherWindow::Heading" text="labels.favourites" bg.color="bg_schema" pad.v="15"/>
						<void bg.color="bg_name" pad.v="1" vreduce="true"/>
						<sarea expand="true" vscroll="optional" hscale="1">
							<vbox ui:id="favourites_list" expand="true" pad.v="4" pad.h="6"/>
						</sarea>
					</vbox>
				</tab>
			</tabs>
		</vbox>

		<hsep ui:inject="LauncherWindow::HSep::Header"/>

		<!-- Footer -->
		<hbox height="20" bg.color="bg_schema" spacing="6">
			<!-- UI Scale icons + and - -->
			<hbox padding.left="6">
				<label ui:id="trg_ui_scaling" font.name="lsp-icons" hover="true" color="footer_icon" hover.color="footer_icon_hover" padding.right="10" font.size="12" font.antialias="true" text="icons.main.scale" pointer="hand"/>
				<label ui:id="trg_ui_zoom_in" font.name="lsp-icons" hover="true" color="footer_icon_rsz" hover.color="footer_icon_rsz_hover" padding.right="5" expand="false" font.size="10" font.antialias="true" text="icons.main.plus_nb" pointer="hand"/>
				<label ui:id="trg_ui_zoom_out" font.name="lsp-icons" hover="true" color="footer_icon_rsz" hover.color="footer_icon_rsz_hover" padding.right="5" expand="false" font.size="10" font.antialias="true" text="icons.main.minus_nb" pointer="hand"/>
			</hbox>

			<!-- Text scale icons + and - -->
			<hbox padding.left="3">
				<label ui:id="trg_font_scaling" font.name="lsp-icons" hover="true" color="footer_icon" hover.color="footer_icon_hover" padding.right="10" font.size="12" font.antialias="true" text="icons.main.font" pointer="hand"/>
				<label ui:id="trg_font_zoom_in" font.name="lsp-icons" hover="true" color="footer_icon_rsz" hover.color="footer_icon_rsz_hover" padding.right="5" expand="false" font.size="10" font.antialias="true" text="icons.main.plus_nb" pointer="hand"/>
				<label ui:id="trg_font_zoom_out" font.name="lsp-icons" hover="true" color="footer_icon_rsz" hover.color="footer_icon_rsz_hover" padding.right="5" expand="false" font.size="10" font.antialias="true" text="icons.main.minus_nb" pointer="hand"/>
			</hbox>

			<!-- Empty filler -->
			<void expand="true"/>

			<!-- Help icon -->
			<label ui:id="trg_show_manual" font.name="lsp-icons" font.size="12" font.antialias="true" text="icons.main.help" hover="true" color="footer_icon_rsz" hover.color="menu_icon_hover" halign="1" pointer="hand"/>
		</hbox>
	</vbox>
</window>
